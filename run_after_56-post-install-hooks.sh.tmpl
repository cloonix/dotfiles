#!/usr/bin/env bash
{{ template "helpers.sh" . }}

set -e

{{- $profile := .profile | default "basic" }}
{{- $basicPackages := index .packages "basic" | default dict }}
{{- $profilePackages := dict }}
{{- if ne $profile "basic" }}
{{- $profilePackages = index .packages $profile | default dict }}
{{- end }}
{{- $allBrews := $basicPackages.brews | default list }}
{{- range (index $profilePackages "brews" | default list) }}{{ $allBrews = append $allBrews . }}{{ end }}

{{- if has "yazi" $allBrews }}
setup_brew_path

if command -v ya >/dev/null 2>&1; then
    section "Post-Install: Yazi Plugins"
    progress "Installing yazi plugins via ya pkg install"
    rm -rf "$HOME/.config/yazi/plugins" "$HOME/.config/yazi/flavors"
    if (cd "$HOME/.config/yazi" && ya pkg install) >/dev/null 2>&1; then finish; else failed; exit 1; fi
fi
{{- end }}

{{- if or (eq $profile "dev") (eq $profile "mac") }}
# GITHUB_TOKEN is sourced from ~/.env (rendered from private_dot_env.tmpl by
# chezmoi locally and shipped pre-rendered to remotes via chezmoi archive).
# GIT_TERMINAL_PROMPT=0 + GIT_ASKPASS=true prevent git from ever blocking on a
# prompt. credential.helper= clears the macOS keychain helper per git call.
[ -f "$HOME/.env" ] && source "$HOME/.env"
export GIT_TERMINAL_PROMPT=0
export GIT_ASKPASS=true

if command -v claude >/dev/null 2>&1; then
    section "Claude MCP Servers"

    if [ -n "${CONTEXT7_API_KEY:-}" ]; then
        try "Adding context7 MCP" claude mcp add \
            --transport http \
            --header "CONTEXT7_API_KEY: ${CONTEXT7_API_KEY}" \
            --scope user \
            "context7" "https://mcp.context7.com/mcp"
    else
        info "Skipping context7: CONTEXT7_API_KEY not set"
    fi

    try "Adding service-hub MCP" claude mcp add \
        --transport http \
        --scope user \
        "service-hub" "{{ output "gopass" "--password" "api/servicehub" "url" | trim }}/mcp"

    if [ -n "${FIRECRAWL_URL:-}" ]; then
        try "Adding firecrawl MCP" claude mcp add \
            --transport http \
            --scope user \
            "firecrawl" "${FIRECRAWL_URL}"
    else
        info "Skipping firecrawl: FIRECRAWL_URL not set"
    fi
fi

section "Claude Config Repo"
readonly CLAUDE_REPO_DIR="$HOME/git/claude"
mkdir -p "$HOME/git"
if [ ! -d "$CLAUDE_REPO_DIR/.git" ]; then
    try "Cloning cloonix/claude" git \
        clone git@github.com:cloonix/claude.git "$CLAUDE_REPO_DIR"
else
    current_url=$(git -C "$CLAUDE_REPO_DIR" remote get-url origin 2>/dev/null)
    if [[ "$current_url" == https://github.com/* ]]; then
        git -C "$CLAUDE_REPO_DIR" remote set-url origin "${current_url/https:\/\/github.com\//git@github.com:}"
    fi
    try "Updating cloonix/claude" git -C "$CLAUDE_REPO_DIR" \
        pull --ff-only
fi
mkdir -p "$HOME/.claude/skills"
try "Deploying claude skills" cp -r "$CLAUDE_REPO_DIR/skills/." "$HOME/.claude/skills/"

{{- if has "fabric-ai" $allBrews }}
setup_brew_path

if command -v fabric-ai >/dev/null 2>&1; then
    section "Post-Install: Fabric AI"

    readonly FABRIC_REPO_DIR="$HOME/git/fabric"
    readonly FABRIC_TIMESTAMP="$HOME/.cache/fabric-last-update"
    readonly UPDATE_INTERVAL_DAYS=7

    mkdir -p "$HOME/.cache" "$HOME/git"

    # Personal patterns — always sync
    [ -d "$FABRIC_REPO_DIR" ] && [ ! -d "$FABRIC_REPO_DIR/.git" ] && rm -rf "$FABRIC_REPO_DIR"
    if [ ! -d "$FABRIC_REPO_DIR" ]; then
        try "Cloning personal fabric patterns" git \
            clone git@github.com:cloonix/fabric.git "$FABRIC_REPO_DIR"
    else
        current_url=$(git -C "$FABRIC_REPO_DIR" remote get-url origin 2>/dev/null)
        if [[ "$current_url" == https://github.com/* ]]; then
            git -C "$FABRIC_REPO_DIR" remote set-url origin "${current_url/https:\/\/github.com\//git@github.com:}"
        fi
        try "Updating personal fabric patterns" git -C "$FABRIC_REPO_DIR" \
            pull
    fi

    # Upstream patterns — throttled to every 7 days
    needs_update=false
    if [ ! -f "$FABRIC_TIMESTAMP" ]; then
        needs_update=true
    else
        time_diff=$(( ($(date +%s) - $(cat "$FABRIC_TIMESTAMP")) / 86400 ))
        [ "$time_diff" -ge "$UPDATE_INTERVAL_DAYS" ] && needs_update=true
    fi

    if [ "$needs_update" = true ]; then
        try "Updating upstream fabric-ai patterns" fabric-ai -U
        date +%s > "$FABRIC_TIMESTAMP"
    else
        success "Upstream fabric patterns up-to-date (last updated $time_diff days ago)"
    fi
fi
{{- end }}
{{- end }}
