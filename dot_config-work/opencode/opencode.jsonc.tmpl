{{- $rsn := output "gopass" "--password" "work/api/azure" "rsn" | trim -}}
{{- $azureKey := gopass "work/api/azure" -}}
{{- $fhgenie := output "gopass" "--password" "work/api/fhgenie" "url" | trim -}}
{{- $fhgenieKey := gopass "work/api/fhgenie" -}}
{{- $bedrockToken := gopass "work/api/awsbedrock" -}}
{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "enabled_providers": [
    "azure-openai",
    "azure-anthropic",
    "azure-kimi",
    "fhgenie",
    "amazon-bedrock"
  ],
  "model": "azure-openai/gpt-5.5",
  "small_model": "azure-openai/gpt-5.4",
  "provider": {
    // SDK: @ai-sdk/azure — Azure Cognitive Services endpoint (GPT, Grok)
    // All standard OpenAI params supported for GPT models.
    // Grok Code Fast 1 is a reasoning model: presencePenalty/frequencyPenalty unsupported.
    "azure-openai": {
      "name": "Azure Fraunhofer (Cognitive Services)",
      "npm": "@ai-sdk/azure",
      "options": {
        "baseURL": "https://{{ $rsn }}.cognitiveservices.azure.com/openai",
        "apiKey": "{{ $azureKey }}"
      },
      "models": {
        // GPT-5 reasoning models: use real input/output limits, OpenCode reasoning defaults,
        // and omit unsupported sampling params.
        "gpt-5.4": {
          "name": "GPT-5.4",
          "id": "gpt-5.4",
          "limit": {
            "context": 922000,
            "output": 128000
          },
          "options": {
            "reasoningEffort": "medium",
            "textVerbosity": "low"
          }
        },
        "gpt-5.5": {
          "name": "GPT-5.5",
          "id": "gpt-5.5",
          "limit": {
            "context": 922000,
            "output": 128000
          },
          "options": {
            "reasoningEffort": "medium",
            "textVerbosity": "low"
          }
        },
        // Reasoning model: presencePenalty + frequencyPenalty unsupported (xAI docs)
        "grok-code-fast-1": {
          "name": "Grok Code Fast 1",
          "id": "grok-code-fast-1",
          "limit": {
            "context": 256000,
            "output": 8192
          },
          "options": {
            "temperature": 0.3,
            "topP": 0.9
          }
        }
      }
    },
    // SDK: @ai-sdk/anthropic — Azure AI Foundry Anthropic endpoint
    // Claude 4.6/4.7 on Azure Foundry use 1M-token contexts.
    // Adaptive thinking is the current default-safe mode; manual budgetTokens is deprecated
    // on 4.6 and rejected on 4.7.
    "azure-anthropic": {
      "name": "Azure Fraunhofer (Anthropic)",
      "npm": "@ai-sdk/anthropic",
      "options": {
        "baseURL": "https://{{ $rsn }}.services.ai.azure.com/anthropic/v1",
        "apiKey": "{{ $azureKey }}"
      },
      "models": {
        "claude-opus-4-6": {
          "id": "claude-opus-4-6",
          "name": "Claude Opus 4.6",
          "limit": {
            "context": 1000000,
            "output": 128000
          }
        },
        "claude-opus-4-7": {
          "id": "claude-opus-4-7",
          "name": "Claude Opus 4.7",
          "limit": {
            "context": 1000000,
            "output": 128000
          }
        },
        "claude-sonnet-4-6": {
          "id": "claude-sonnet-4-6",
          "name": "Claude Sonnet 4.6",
          "limit": {
            "context": 1000000,
            "output": 128000
          },
          "options": {
            "thinking": {
              "type": "adaptive"
            },
            "effort": "medium"
          }
        }
      }
    },
    // SDK: @ai-sdk/openai-compatible — Azure AI Foundry OpenAI-compatible endpoint
    // Kimi K2.5: temperature, topP, presencePenalty, frequencyPenalty are fixed by API — omit all
    // Kimi K2 Thinking: reasoning model, temperature defaults to 1.0 per Moonshot docs
    // DeepSeek V3.2: topP, frequencyPenalty, presencePenalty unsupported on Azure endpoint
    // Codestral 2501: Azure partner docs confirm larger context but only 4k output
    "azure-kimi": {
      "name": "Azure Fraunhofer (AI Foundry)",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://{{ $rsn }}.services.ai.azure.com/openai/v1",
        "apiKey": "{{ $azureKey }}"
      },
      "models": {
        // Reasoning model: temperature fixed to 1.0 by API
        "Kimi-K2-Thinking": {
          "name": "Kimi K2 Thinking",
          "id": "Kimi-K2-Thinking",
          "limit": {
            "context": 131072,
            "output": 32768
          },
          "options": {
            "temperature": 1.0
          }
        },
        // K2.5: all sampling params fixed by API — no options needed
        "Kimi-K2.5": {
          "name": "Kimi K2.5",
          "id": "Kimi-K2.5",
          "limit": {
            "context": 262144,
            "output": 262144
          }
        },
        // Only temperature confirmed supported on Azure AI Foundry endpoint
        "DeepSeek-V3.2": {
          "name": "DeepSeek V3.2",
          "id": "DeepSeek-V3.2",
          "limit": {
            "context": 128000,
            "output": 128000
          },
          "options": {
            "temperature": 0.3
          }
        },
        // Sampling defaults retained from the prior config; only Azure partner limits were revalidated
        "Codestral-2501": {
          "name": "Codestral 2501",
          "id": "Codestral-2501",
          "limit": {
            "context": 262144,
            "output": 4096
          },
          "options": {
            "temperature": 0.2,
            "topP": 0.9,
            "frequencyPenalty": 0.1,
            "presencePenalty": 0.1
          }
        }
      }
    },
    // SDK: @ai-sdk/openai-compatible — Fraunhofer internal gateway (different baseURL, separate group)
    "fhgenie": {
      "id": "fhgenie",
      "npm": "@ai-sdk/openai-compatible",
      "name": "fhgenie",
      "api": "{{ $fhgenie }}/v1",
      "options": {
        "apiKey": "{{ $fhgenieKey }}"
      },
      "models": {
        // Chat models verified against /chat/completions on 2026-04-29.
        "MiniMaxAI/MiniMax-M2.5": {
          "name": "MiniMax M2.5"
        },
        "Qwen/Qwen3-Coder-Next-FP8": {
          "name": "Qwen3 Coder Next FP8"
        },
        "nvidia/Orchestrator-8B": {
          "name": "NVIDIA Orchestrator 8B"
        },
        "openGPT-X/Teuken-7B-instruct-v0.6": {
          "name": "Teuken 7B Instruct v0.6"
        }
      }
    },
    // SDK: built-in amazon-bedrock — AWS Bedrock runtime (eu-central-1)
    // Auth: bearer token takes precedence over profile/credential chain (opencode docs).
    // Model IDs are full ARNs of EU cross-region inference profiles (verified against AWS docs).
    // Direct on-demand model IDs are NOT supported for Claude 4.x models.
    "amazon-bedrock": {
      "name": "Amazon Bedrock (Fraunhofer)",
      "options": {
        "region": "eu-central-1",
        "apiKey": "{{ $bedrockToken }}"
      },
      "models": {
        "arn:aws:bedrock:eu-central-1::inference-profile/eu.anthropic.claude-opus-4-7-v1": {
          "name": "Claude Opus 4.7 (Bedrock EU)",
          "id": "arn:aws:bedrock:eu-central-1::inference-profile/eu.anthropic.claude-opus-4-7-v1",
          "limit": {
            "context": 1000000,
            "output": 128000
          }
        },
        "arn:aws:bedrock:eu-central-1::inference-profile/eu.anthropic.claude-opus-4-6-v1": {
          "name": "Claude Opus 4.6 (Bedrock EU)",
          "id": "arn:aws:bedrock:eu-central-1::inference-profile/eu.anthropic.claude-opus-4-6-v1",
          "limit": {
            "context": 1000000,
            "output": 128000
          }
        },
        "arn:aws:bedrock:eu-central-1::inference-profile/eu.anthropic.claude-sonnet-4-6": {
          "name": "Claude Sonnet 4.6 (Bedrock EU)",
          "id": "arn:aws:bedrock:eu-central-1::inference-profile/eu.anthropic.claude-sonnet-4-6",
          "limit": {
            "context": 1000000,
            "output": 64000
          }
        },
        "arn:aws:bedrock:eu-central-1::inference-profile/eu.anthropic.claude-haiku-4-5-20251001-v1:0": {
          "name": "Claude Haiku 4.5 (Bedrock EU)",
          "id": "arn:aws:bedrock:eu-central-1::inference-profile/eu.anthropic.claude-haiku-4-5-20251001-v1:0",
          "limit": {
            "context": 200000,
            "output": 64000
          }
        }
      }
    }
  }
}
